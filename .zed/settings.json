{
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSX": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    }
  }
}
